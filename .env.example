# ============================================================
# Chronos Lab · environment
# Copy to `.env` (gitignored). Never commit secret keys.
# ============================================================

# --- Browser (Vite) ---
# Local Docker:  npm run supabase:start && npm run supabase:env
# Hosted:        Dashboard → Project Settings → API Keys
VITE_SUPABASE_URL=https://gkyhqnjgwxlyzptpiiob.supabase.co
# Prefer the new publishable key (sb_publishable_...). Legacy JWT anon key still works.
VITE_SUPABASE_ANON_KEY=sb_publishable_...
# Optional alias (client falls back to this if ANON_KEY is unset)
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Optional local flags
VITE_DEBUG=false
# Playwright only — enables mock session when localStorage chronos.e2e.auth=1
# VITE_E2E_AUTH=true

# Client error monitoring (production: GitHub Actions secret VITE_SENTRY_DSN)
# VITE_SENTRY_DSN=https://YOUR_KEY@o0.ingest.sentry.io/0

# --- Server / @supabase/server (Node, Workers, local tooling) ---
# On Supabase Edge Functions these are injected automatically — no setup needed.
# For other runtimes (and local scripts using createSupabaseContext), set:
SUPABASE_URL=https://gkyhqnjgwxlyzptpiiob.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Secret key — Dashboard → API Keys → create/manage secret. NEVER VITE_ / never browser.
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_JWKS_URL=https://gkyhqnjgwxlyzptpiiob.supabase.co/auth/v1/.well-known/jwks.json

# --- Supabase CLI (local only — never commit) ---
# Create at https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=sbp_...
# npx supabase link --project-ref gkyhqnjgwxlyzptpiiob

