# Supabase (browser)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Optional local flags
VITE_MOCK_ACCESS_REQUESTS=false
VITE_DEBUG=false

# Supabase CLI (local only — never commit)
# SUPABASE_ACCESS_TOKEN=sbp_...

# Grok / xAI — set as Edge Function secret (never VITE_ / never browser)
# supabase secrets set XAI_API_KEY=xai-...
# XAI_API_KEY=xai-...
