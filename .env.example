# Supabase (browser)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Optional local flags
VITE_DEBUG=false
# Playwright only — enables mock session when localStorage chronos.e2e.auth=1
# VITE_E2E_AUTH=true

# Client error monitoring (optional — leave empty for console-only)
# VITE_SENTRY_DSN=https://YOUR_KEY@o0.ingest.sentry.io/0

# Supabase CLI (local only — never commit)
# SUPABASE_ACCESS_TOKEN=sbp_...

# Grok / xAI — set as Edge Function secret (never VITE_ / never browser)
# supabase secrets set XAI_API_KEY=xai-...
# XAI_API_KEY=xai-...
